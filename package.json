{
  "name": "plrei-online-branding",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean:next": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "dev:clean": "npm run clean:next && next dev",
