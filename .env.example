# ------------------------------------------------------------------------------
# Database (Supabase Postgres / Vercel)
# ------------------------------------------------------------------------------
# Prisma runtime URL (pooled)
POSTGRES_PRISMA_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1
# Prisma direct URL (migrations/introspection, non-pooling)
POSTGRES_URL_NON_POOLING=postgresql://USER:PASSWORD@HOST:5432/postgres

# Optional compatibility fallback (legacy local setups)
DATABASE_URL=
POSTGRES_URL=
POSTGRES_HOST=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ------------------------------------------------------------------------------
# Supabase public client configuration (safe in browser)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
# Optional fallback alias if your Vercel project uses it
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ------------------------------------------------------------------------------
# Supabase server-only secrets (DO NOT expose to client)
# ------------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional alias/fallback names present in some projects
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWT_SECRET=

# ------------------------------------------------------------------------------
# Auth.js
# ------------------------------------------------------------------------------
AUTH_SECRET=replace-with-a-random-32+-char-secret
AUTH_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Admin bootstrap
# ------------------------------------------------------------------------------
ADMIN_EMAIL=admin@plrei.com
ADMIN_PASSWORD_HASH=$2a$10$replace.with.a.real.bcrypt.hash

# ------------------------------------------------------------------------------
# Signature gate and signed signature links
# ------------------------------------------------------------------------------
SIGNATURE_SECRET_KEY=replace-with-a-long-random-secret
# Static hash required inside decoded ?s payload to bypass auth on /email-signature
SIGNATURE_BYPASS_HASH=replace-with-random-shared-hash

# Encryption key used for SSO secrets stored in database (falls back to AUTH_SECRET if omitted)
SSO_ENCRYPTION_KEY=replace-with-a-random-32+-char-secret

# Legacy fallback for SSO providers if DB config is empty
SSO_PROVIDERS_JSON={}

# ------------------------------------------------------------------------------
# Resend API
# ------------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=PLREI Signatures <signatures@your-verified-domain.com>
